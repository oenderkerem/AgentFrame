"integration.overview_title" = "Wie funktioniert die Integration?";
"integration.overview_desc" = "Dein KI-Agent sendet Status-Signale an AgentFrame — zum Beispiel »busy« wenn er mit der Arbeit beginnt und »done« wenn er fertig ist. AgentFrame reagiert sofort und zeigt den entsprechenden farbigen Bildschirmrahmen an. Du kannst zwischen zwei Übertragungswegen wählen:";
"integration.transport_http_title" = "HTTP-Server";
"integration.transport_http_desc" = "AgentFrame startet einen lokalen Webserver auf deinem Mac. Dein Agent ruft per curl einen einfachen POST-Endpoint auf — keine externe Verbindung, alles läuft lokal.";
"integration.transport_file_title" = "Datei-Überwachung";
"integration.transport_file_desc" = "Dein Agent schreibt »busy«, »done« oder »idle« in eine Textdatei. AgentFrame beobachtet diese Datei auf OS-Ebene und reagiert in Echtzeit auf jede Änderung — kein Netzwerk erforderlich.";
"integration.overview_global_hint" = "Einmalig einrichten — die Hooks gelten global für alle Projekte und Sessions. Für Claude Code kann der Snippet alternativ manuell in .claude/settings.json im jeweiligen Projektverzeichnis eingefügt werden, um die Integration auf ein einzelnes Projekt zu begrenzen.";

