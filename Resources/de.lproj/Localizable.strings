/* About Window */
"about.support" = "Auf Ko-fi unterstützen";
"about.title" = "Über AgentFrame";
"about.subtitle" = "Bildschirmrahmen-Anzeige für KI-Coding-Agenten";
"about.how_it_works" = "So funktioniert es";
"about.how_desc" = "AgentFrame sitzt in der Menüleiste und wartet auf Signale deines KI-Coding-Agenten. Je nach aktuellem Status des Agenten wird ein farbiger Rahmen um den Bildschirm gezeichnet — so siehst du auf einen Blick, ob dein Agent gerade arbeitet, fertig ist oder wartet.";
"about.state_busy" = "Beschäftigt — Ein farbiger Rahmen erscheint an den konfigurierten Bildschirmkanten.";
"about.state_waiting" = "Wartet auf Eingabe — Der Rahmen wechselt zur Wartefarbe, wenn der Agent deine Eingabe braucht.";
"about.state_done" = "Fertig — Der Rahmen wechselt die Farbe und löst optional einen Vollbild-Flash aus.";
"about.state_idle" = "Bereit — Der Rahmen verschwindet.";
"about.http_title" = "HTTP-API";
"about.http_desc" = "AgentFrame startet einen lokalen HTTP-Server (Standard-Port 7842). Dein Agent sendet einen POST-Request um seinen Status mitzuteilen — keine Bibliothek nötig, ein einfacher curl-Aufruf reicht:";
"about.file_title" = "Datei-Überwachung";
"about.file_desc" = "Alternativ zum HTTP-Server kann dein Agent einfach einen Text in eine Datei schreiben. AgentFrame beobachtet die konfigurierte Datei mit einem OS-Level-File-Watcher (kqueue) und reagiert in Echtzeit — ganz ohne Netzwerk:";
"about.hooks_title" = "Agenten automatisch verbinden";
"about.hooks_desc" = "Öffne Einstellungen → Integration und wähle deinen Agenten sowie die Transport-Methode. Ein Klick auf »Automatisch installieren« schreibt die passenden Hooks direkt in die Konfigurationsdatei deines Agenten — kein manuelles Editieren nötig.\n\nClaude Code: Drei Hooks in ~/.claude/settings.json — PreToolUse (»busy«), Notification (»waiting« wenn Claude auf Eingabe wartet) und Stop (»done«).\n\nCodex: Die Keys onStart (»busy«) und onFinish (»done«) in ~/.codex/config.json. Der Wartezustand ist für Codex nicht verfügbar, da kein Notification-Hook existiert.\n\nBenutzerdefinierte Agenten können alle vier Endpoints direkt aufrufen: /busy, /waiting, /done, /idle.";
"about.customize_hint" = "Anpassbar — Farben, Rahmendicke, Bildschirmkanten und Flash-Effekt lassen sich in den Einstellungen frei konfigurieren.";

