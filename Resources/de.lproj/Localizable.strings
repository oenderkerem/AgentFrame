"integration.hook_desc_claude" = "»Automatisch installieren« schreibt drei Hooks in ~/.claude/settings.json: PreToolUse (sendet »busy«), Notification (sendet »waiting« wenn Claude auf deine Eingabe wartet) und Stop (sendet »done«). Die genauen Befehle siehst du im Snippet unten. Bestehende Hooks anderer Apps bleiben unverändert.";
"integration.hook_desc_codex" = "»Automatisch installieren« setzt die Keys onStart (sendet »busy«) und onFinish (sendet »done«) in ~/.codex/config.json. Codex bietet keinen Notification-Hook — der Wartezustand steht dort nicht zur Verfügung. Andere Einstellungen in der Datei bleiben unverändert.";
"integration.hook_desc_custom" = "Kopiere den Code unten und füge ihn manuell in die Konfigurationsdatei deines Agenten ein.";
"integration.mode_file_watch" = "Datei-Überwachung";
