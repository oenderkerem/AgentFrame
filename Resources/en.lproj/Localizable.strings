/* About Window */
"about.support" = "Support on Ko-fi";
"about.title" = "About AgentFrame";
"about.subtitle" = "Screen frame indicator for AI coding agents";
"about.how_it_works" = "How it works";
"about.how_desc" = "AgentFrame sits in your menu bar and watches for signals from your AI coding agent. Depending on the agent's current state, it draws a colored border around your screen — so you always know at a glance whether your agent is working, done, or idle.";
"about.state_busy" = "Busy — A colored frame appears at the screen edges you configured.";
"about.state_waiting" = "Waiting for input — The frame switches to the waiting color when the agent needs your input.";
"about.state_done" = "Done — The frame switches to the done color and optionally triggers a full-screen flash.";
"about.state_idle" = "Idle — The frame disappears.";
"about.http_title" = "HTTP API";
"about.http_desc" = "AgentFrame starts a local HTTP server (default port 7842). Your agent sends a POST request to signal its state — no library or SDK required, a plain curl call is enough:";
"about.file_title" = "File Watching";
"about.file_desc" = "As an alternative to the HTTP server, your agent can simply write a word into a text file. AgentFrame monitors the configured file using an OS-level file watcher (kqueue) and reacts in real time — no network connection needed:";
"about.hooks_title" = "Connecting your agent automatically";
"about.hooks_desc" = "Open Settings → Integration and choose your agent and transport method. One click on »Install Automatically« writes the right hooks directly into your agent's configuration file — no manual editing required.\n\nClaude Code: Three hooks in ~/.claude/settings.json — PreToolUse (»busy«), Notification (»waiting« when Claude needs your input), and Stop (»done«).\n\nCodex: The onStart (»busy«) and onFinish (»done«) keys in ~/.codex/config.json. The waiting state is not available for Codex as it has no notification hook.\n\nCustom agents can call all four endpoints directly: /busy, /waiting, /done, /idle.";
"about.customize_hint" = "Customizable — Colors, frame thickness, screen edges, and the flash effect can all be configured in Settings.";

