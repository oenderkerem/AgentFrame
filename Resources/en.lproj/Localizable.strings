"integration.overview_title" = "How does integration work?";
"integration.overview_desc" = "Your AI agent sends status signals to AgentFrame — for example »busy« when it starts working and »done« when it finishes. AgentFrame reacts immediately and shows the corresponding colored screen frame. You can choose between two transport methods:";
"integration.transport_http_title" = "HTTP Server";
"integration.transport_http_desc" = "AgentFrame starts a local web server on your Mac. Your agent sends a simple POST request via curl — no external connections, everything runs locally.";
"integration.transport_file_title" = "File Watching";
"integration.transport_file_desc" = "Your agent writes »busy«, »done«, or »idle« into a text file. AgentFrame monitors this file at the OS level and reacts in real time to any change — no network required.";
"integration.overview_global_hint" = "Set up once — hooks apply globally across all projects and sessions. For Claude Code, the snippet can alternatively be added manually to .claude/settings.json in the project directory to limit the integration to a single project.";

